<!DOCTYPE html>
<html lang="pt-BR">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <title>Treinamento Pycubator</title>
  <link rel="stylesheet" href="revealjs/css/theme/black.css">
  <link href="img/favicon.ico" rel="icon" type="image/x-icon" />
  <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
  <style>
    body {
      background-image: linear-gradient(rgba(0, 0, 0, 0), rgba(0, 0, 0, 1)), url(img/nccode_bg.png);
      background-repeat: no-repeat;
      background-size: auto;
      background-position-x: center;
      background-position-y: top;
      margin-top: 280px !important;
    }

    code {
      background-color: rgba(255, 255, 255, 0.1);
      font-family: monospace;
      color: #fc6c1f;
    }

    .panel {
      padding: 15px;
      background-color: rgba(0, 0, 0, 0.5)
    }
  </style>
</head>

<body class="reveal" style="margin: auto;">
  <div class="panel m-auto lg:mx-14 xl:mx-40 mx-4">
    <div class="grid md:grid-cols-3">

      <div class="col-span-2 md:pb-0 pb-10">
        <h3>Aulas</h3>
        <ol>
          {% for _, filename, title in nccode_slides %}
          <li><a href="{{ filename }}">{{ title }}</a></li>
          {% endfor %}
        </ol>
      </div>
      <div>
        <h3>Referência</h3>
        <ol>
          {% for _, filename, title in slides %}
          <li><a href="{{ filename }}">{{ title }}</a></li>
          {% endfor %}
        </ol>
      </div>
    </div>
  </div>

  <footer>
    <p>
      <small>Criado por Noam Elfanbaum (<a href="http://twitter.com/noamelf">@noamelf</a>) and
        Udi Oron (<a href="https://twitter.com/nonZero">@nonZero</a>).
      </small>
      <small>Traduzido Por Gilson Filho (<a href="http://twitter.com/gilsonfilho">@gilsonfilho</a>)
    </p>
  </footer>
</body>

</html>